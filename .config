#
# Architecture
#
#CONFIG_BOARD_LPC55S69=y
CONFIG_BOARD_MCXA153=y
CONFIG_BOARD_TYPE="mcxa153"
CONFIG_LTO=y
CONFIG_DEBUG=y
CONFIG_STACK_PROT=y

#
# Kernel
#
CONFIG_ROOTFS_DEV_MAJOR=2
CONFIG_ROOTFS_DEV_MINOR=0
CONFIG_ROOTFS_TYPE="ucfs"
CONFIG_INIT_PATH="/bin/init"
CONFIG_INIT_CONSOLE_RDEV=0
CONFIG_INIT_CONSOLE_WDEV=0
CONFIG_VFS_MAXFILES=32
CONFIG_VFS_MAXMOUNTS=2
CONFIG_PROC_MAXFILES=32
CONFIG_PROC_MAX_PROC=4
CONFIG_PROC_KSTACK_SIZE=512

#
# File systems
#
CONFIG_FS_UCFS=y
# CONFIG_FS_ROMFS is not set

#
# Drivers
#
CONFIG_TTY_DRIVER=y
CONFIG_USART_DRIVER=y
CONFIG_USART_DRIVER_MCXA=y
#CONFIG_USART_DRIVER_LPC55S69=y


#CONFIG_HD44XXX_DRIVER=y
#CONFIG_HD44XXX_DRIVER_HD44780=y
#CONFIG_HD44XXX_DRIVER_ST7920=y

CONFIG_ROMDISK_DRIVER=y
